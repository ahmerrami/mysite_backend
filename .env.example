# Configuration Django

# Environnement : 'development', 'test', 'production'
DJANGO_ENV=development

# Clé secrète (générer une nouvelle clé sécurisée en production)
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# Nom de la société/organisation
SOCIETE=MySite

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Origines CORS autorisées (séparés par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# IPs bloquées (séparées par des virgules, optionnel)
BLOCKED_IPS=

# Configuration Base de Données MySQL
DB_ENGINE=django.db.backends.mysql
DB_NAME=mysite_db
DB_USER=mysite_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=3306

# Email (SMTP)
AUTHEMAIL_EMAIL_HOST=smtp.gmail.com
AUTHEMAIL_EMAIL_PORT=587
AUTHEMAIL_EMAIL_HOST_USER=your-email@example.com
AUTHEMAIL_EMAIL_HOST_PASSWORD=your-app-password

# En dev: console par defaut; pour un vrai envoi, decommenter/definir SMTP backend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Destinataires du rapport hebdomadaire (separes par des virgules)
TO_DESTINATAIRES_BC=finance@example.com,recouvrement@example.com

# Stockage SFTP (optionnel, pour les backups)
SFTP_HOST=ivyerrami.ddns.net
SFTP_PORT=22
SFTP_USERNAME=your-sftp-user
SFTP_PASSWORD=your-sftp-password
SFTP_ROOT_PATH=/backup
